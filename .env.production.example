# Production environment — copy to `.env.production` on the server and fill in.
#   cp .env.production.example .env.production && nano .env.production
#
# Domain is pre-filled for foodila.ir. Generate each secret freshly:
#   AUTH_SECRET / passwords :  openssl rand -base64 32
#   IMGPROXY_KEY / _SALT    :  openssl rand -hex 32
# Never commit this filled-in file. (.env* is gitignored; only the .example is tracked.)

NODE_ENV=production

# ── Domain & TLS ─────────────────────────────────────────────────────────────
# Create three DNS A records → this server's IP:  foodila.ir, cdn.foodila.ir, s3.foodila.ir
DOMAIN=foodila.ir
CDN_HOST=cdn.foodila.ir
S3_HOST=s3.foodila.ir
CERTBOT_EMAIL=you@foodila.ir

# ── Host-nginx mode (Plan B: a web server already runs on this host) ──────────
# The stack publishes each upstream on 127.0.0.1 for the HOST nginx to reverse-proxy.
# Override only if these localhost ports are already taken on the server.
APP_HOST_PORT=3100
IMGPROXY_HOST_PORT=8100
S3_HOST_PORT=9100
# (DOMAIN/CDN_HOST/S3_HOST above are only consumed by the OPT-IN bundled nginx — `--profile bundled-edge`.)

# ── Auth.js (NextAuth v5) ────────────────────────────────────────────────────
AUTH_SECRET=replace_me_openssl_rand_base64_32
AUTH_URL=https://foodila.ir
AUTH_TRUST_HOST=true

# ── Database (Postgres service is reachable as host `postgres` on the internal network) ──
POSTGRES_USER=cafe
POSTGRES_PASSWORD=replace_me_strong_password
POSTGRES_DB=cafe_menu
DATABASE_URL=postgresql://cafe:replace_me_strong_password@postgres:5432/cafe_menu?schema=public

# ── Object storage (MinIO) ───────────────────────────────────────────────────
# Root creds for the MinIO service:
MINIO_ROOT_USER=cafe-minio
MINIO_ROOT_PASSWORD=replace_me_strong_password
# Credentials the app + imgproxy authenticate with — set EQUAL to the root creds above
# (or create a scoped access key in MinIO and use that):
MINIO_ACCESS_KEY=cafe-minio
MINIO_SECRET_KEY=replace_me_strong_password
MINIO_BUCKET=cafe-menu
# Public origin browsers use for presigned uploads (through nginx → MinIO):
MINIO_ENDPOINT=https://s3.foodila.ir
# In-cluster address the server uses for direct reads/writes (no TLS/proxy round-trip):
MINIO_INTERNAL_ENDPOINT=http://minio:9000

# ── imgproxy ─────────────────────────────────────────────────────────────────
# Public origin browsers fetch transformed images from (through nginx → imgproxy):
IMGPROXY_URL=https://cdn.foodila.ir
IMGPROXY_KEY=replace_me_openssl_rand_hex_32
IMGPROXY_SALT=replace_me_openssl_rand_hex_32
