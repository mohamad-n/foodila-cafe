# Copy to .env for local development. Values below match docker-compose.yml.
# Never commit a real .env — it is gitignored.

# --- Database (Phase 2) ---
# Ports match docker-compose.yml (remapped high to avoid clashes with other local services).
DATABASE_URL="postgresql://cafe:cafe@localhost:5455/cafe_menu?schema=public"

# --- Auth.js / NextAuth v5 (Phase 3) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:4055"

# --- Object storage: MinIO (Phase 5) ---
MINIO_ENDPOINT="http://localhost:9410"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="cafe-menu"

# --- imgproxy (Phase 5) ---
IMGPROXY_URL="http://localhost:8810"
IMGPROXY_KEY="6465765f696d6770726f78795f6b65795f63686d65"
IMGPROXY_SALT="6465765f696d6770726f78795f73616c745f63686d65"
